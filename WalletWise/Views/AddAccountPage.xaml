<!-- Views/AddAccountPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:WalletWise.ViewModels"
             x:Class="WalletWise.Views.AddAccountPage"
             x:DataType="viewmodels:AddAccountViewModel"
             Title="Aggiungi Nuovo Conto">

    <VerticalStackLayout Spacing="10" Padding="20">
        <Label Text="Nome Conto" Style="{StaticResource FormLabel}" />
        <Entry Text="{Binding Name}" Placeholder="Es. Conto Corrente Intesa" />

        <Label Text="Saldo Iniziale" Style="{StaticResource FormLabel}" Margin="0,10,0,0" />
        <Entry Text="{Binding InitialBalanceText}" Placeholder="0.00"
       Keyboard="Numeric" />

        <Label Text="Tipo di Conto" Style="{StaticResource FormLabel}" Margin="0,10,0,0" />
        <Picker ItemsSource="{Binding AccountTypes}"
                SelectedItem="{Binding SelectedAccountType}"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                TitleColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                Title="Seleziona un tipo" />

        <Button Text="Salva Conto" 
                Command="{Binding SaveAccountCommand}"
                Margin="0,20,0,0" />
    </VerticalStackLayout>
</ContentPage>